---
import Layout from "../../layouts/Layout.astro";
import { dataService } from "../../lib/data-service";
import { parseEventDate } from "../../lib/date-utils";
import { slugify } from "../../lib/slugify";
import { getTarget, getRel } from "../../lib/link-utils";

const { slug } = Astro.params;
const data = await dataService.getInitialData();

// Find by Slug (primary) or ID (fallback)
const event = data.events.find(
  (e) => slugify(e.title) === slug || e.id.toString() === slug,
);

if (!event || !event.report_url) {
  return Astro.redirect("/404");
}

const formattedDate = (() => {
  if (!event.date) return "TBA";
  const ts = parseEventDate(event.date);
  if (ts === 0) return event.date;
  return new Date(ts).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
})();
---

<Layout
  title={`Report: ${event.title}`}
  links={data.links}
  injections={data.config.injections}
  colors={data.config.colors}
>
  <div class="flex flex-col lg:flex-row min-h-screen bg-bg-0">
    {/* Left Side: Info (Sticky) */}
    <aside
      class="w-full lg:w-[320px] xl:w-[400px] border-r-2 border-fg-0/10 lg:sticky lg:top-20 overflow-y-auto bg-bg-1 p-6 lg:p-10 space-y-10 shrink-0"
    >
      <div class="space-y-6">
        <div class="flex flex-col gap-2">
          <a
            href="/reports"
            class="inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors"
          >
            ← Back to Reports
          </a>
        </div>

        <h1
          class="text-3xl lg:text-4xl font-black uppercase tracking-tighter leading-[0.9] text-fg-0"
        >
          {event.title}
          <span class="text-primary">Report</span>
        </h1>

        <div class="flex flex-col gap-4 border-l-2 border-fg-0 pl-4 py-1">
          <div class="flex flex-col">
            <span
              class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-1"
              >Event Date</span
            >
            <span class="text-base font-bold text-fg-0 uppercase tracking-tight"
              >{formattedDate}</span
            >
          </div>

          {
            event.venue && (
              <div class="flex flex-col">
                <span class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-1">
                  Venue
                </span>
                <span class="text-base font-bold text-fg-0 uppercase tracking-tight">
                  {event.venue}
                </span>
              </div>
            )
          }
        </div>

        <div class="pt-6 border-t-2 border-fg-0/10 space-y-4">
          <div class="flex flex-col border-2 border-fg-0 p-5 bg-bg-0 shadow-sm">
            <a
              href={event.report_url}
              download={`${event.title.replace(/\s+/g, "_")}_Report.pdf`}
              target={getTarget(event.report_url)}
              rel={getRel(event.report_url)}
              class="w-full py-4 text-center text-xs font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0 flex items-center justify-center gap-2"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                ></path>
              </svg>
              Download Report PDF
            </a>
          </div>
        </div>
      </div>
    </aside>

    {/* Right Side: PDF Viewer */}
    <main class="flex-grow md:p-4 bg-bg-2">
      <div
        class="w-full h-[70vh] lg:h-screen bg-white relative overflow-hidden"
      >
        <iframe
          src={`${event.report_url}#view=FitH&toolbar=1&navpanes=0&scrollbar=1`}
          class="w-full h-full border-none"
          title={`${event.title} Report`}></iframe>
      </div>
    </main>
  </div>
</Layout>

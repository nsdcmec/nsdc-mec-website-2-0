---
// src/pages/[...slug].astro
import Layout from "../layouts/Layout.astro";
import IframeLayout from "../layouts/IframeLayout.astro";
import { dataService } from "../lib/data-service";
import { parseEventDate } from "../lib/date-utils";
import { slugify } from "../lib/slugify";
import ResourcesComponent from "../components/Resources.astro";
import type { Resource } from "../types";

const { slug } = Astro.params;
const safeSlug = slug || "";

const isValidSlug = /^[a-zA-Z0-9-_\/]+$/.test(safeSlug);

if (!isValidSlug) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const route = await dataService.getRoute(safeSlug);
const initialData = await dataService.getInitialData();

if (!route || !initialData) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Logic switch based on route type
if (route.type === "redirect") {
  return Astro.redirect(route.destination_url, 307);
}

// Prepare dynamic resource page data if needed
let sortedTypes: string[] = [];
let groupedResources: Record<string, Resource[]> = {};

if (route.type === "resource-page") {
  const allowedTypes = route.metadata?.types || [];
  const excludedTypes = route.metadata?.excluded_types || [];

  groupedResources = initialData.resources.reduce(
    (acc, resource) => {
      const type = (resource.resource_type || "Other").toLowerCase();

      // Filter by allowed types if provided
      if (
        allowedTypes.length > 0 &&
        !allowedTypes.map((t) => t.toLowerCase()).includes(type)
      ) {
        return acc;
      }

      // Filter by excluded types if provided
      if (
        excludedTypes.length > 0 &&
        excludedTypes.map((t) => t.toLowerCase()).includes(type)
      ) {
        return acc;
      }

      const displayType = resource.resource_type || "Other";
      if (!acc[displayType]) {
        acc[displayType] = [];
      }
      acc[displayType].push(resource);
      return acc;
    },
    {} as Record<string, Resource[]>,
  );

  const predefinedOrder = ["project", "research", "publication", "resource"];
  sortedTypes = Object.keys(groupedResources).sort((a, b) => {
    const idxA = predefinedOrder.indexOf(a.toLowerCase());
    const idxB = predefinedOrder.indexOf(b.toLowerCase());
    if (idxA !== -1 && idxB !== -1) return idxA - idxB;
    if (idxA !== -1) return -1;
    if (idxB !== -1) return 1;
    return a.localeCompare(b);
  });
}

/**
 * Converts a standard Google Form link to its embeddable version.
 * Standard: https://docs.google.com/forms/d/e/.../viewform
 * Embed: https://docs.google.com/forms/d/e/.../viewform?embedded=true
 */
function getEmbedUrl(url: string, type: string) {
  if (type !== "gform") return url;
  try {
    const urlObj = new URL(url);
    if (
      urlObj.hostname.includes("docs.google.com") &&
      urlObj.pathname.includes("/viewform")
    ) {
      urlObj.searchParams.set("embedded", "true");
      return urlObj.toString();
    }
    return url;
  } catch (e) {
    return url;
  }
}

const finalUrl = getEmbedUrl(route.destination_url, route.type);
const pageTitle =
  route.type === "resource-page"
    ? route.destination_url || "Resources"
    : route.destination_url || "External Resource";
const height = route.metadata?.height || "80vh";

// Event Registration Logic
const isEventRegistration = route.metadata?.iseventregistration || false;
const eventId = route.metadata?.eventid;
const event =
  isEventRegistration && eventId
    ? initialData.events.find((e) => e.id.toString() === eventId.toString())
    : null;

const formattedDate = event
  ? (() => {
      if (!event.date) return "TBA";
      const ts = parseEventDate(event.date);
      if (ts === 0) return event.date;
      return new Date(ts).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
      });
    })()
  : null;
---

{
  route.type === "resource-page" ? (
    <Layout
      title={`${pageTitle} | NSDC MEC`}
      links={initialData.links}
      injections={initialData.config.injections}
      colors={initialData.config.colors}
    >
      <div class=" bg-bg-0 min-h-screen">
        {sortedTypes.map((type) => {
          const displayType =
            type.toLowerCase() === "research"
              ? "Research"
              : type.charAt(0).toUpperCase() +
                type.slice(1) +
                (type.endsWith("s") ? "" : "s");
          return (
            <ResourcesComponent
              title={displayType}
              resources={groupedResources[type]}
            />
          );
        })}

        {sortedTypes.length === 0 && (
          <div class="container mx-auto px-4 py-12 text-center">
            <p class="text-fg-1">No resources found for this category.</p>
          </div>
        )}
      </div>
    </Layout>
  ) : route.type === "iframe" ? (
    <IframeLayout title={pageTitle}>
      <iframe
        src={finalUrl}
        class="w-[100dvw] h-[100dvh] border-none overflow-hidden m-0 p-0"
      />
    </IframeLayout>
  ) : (
    <Layout
      title={pageTitle}
      links={initialData.links}
      injections={initialData.config.injections}
      colors={initialData.config.colors}
    >
      {isEventRegistration && event ? (
        <div class="container mx-auto px-4 md:px-6 mt-6 md:mt-16 pb-12">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
            {/* Left Side: Event Details */}
            <div class="md:col-span-3 space-y-6 md:sticky md:top-24 self-start">
              <h1 class="text-3xl md:text-5xl font-black uppercase tracking-tighter leading-[0.9] text-fg-0 break-words">
                {event.title}
              </h1>

              <div class="flex flex-col gap-3 md:gap-4 border-l-2 border-fg-0 pl-4 py-1">
                <div class="flex flex-col">
                  <span class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-0.5">
                    Event Date
                  </span>
                  <span class="font-bold text-fg-0 uppercase tracking-tight">
                    {formattedDate}
                  </span>
                </div>

                {event.venue && (
                  <div class="flex flex-col">
                    <span class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-0.5">
                      Venue
                    </span>
                    <span class="font-bold text-fg-0 uppercase tracking-tight">
                      {event.venue}
                    </span>
                  </div>
                )}
              </div>

              <div class="prose-content text-fg-1 font-sans text-xs md:text-sm leading-relaxed line-clamp-6">
                {event.description}
              </div>

              <a
                href={`/event/${slugify(event.title)}`}
                class="group relative inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary transition-colors"
              >
                <span>View Full Event Details</span>
                <span class="absolute bottom-0 right-0 h-[1px] w-full bg-primary transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
              </a>
            </div>

            {/* Right Side: GForm Iframe */}
            <div class="md:col-span-9" style={{ height: height }}>
              <iframe
                src={finalUrl}
                class="w-full h-full    "
                title={pageTitle}
              >
                Loading...
              </iframe>
            </div>
          </div>
        </div>
      ) : (
        <section
          class="w-full flex flex-col items-center justify-center bg-bg-0 min-h-[80vh] py-12"
          style={{ height: height }}
        >
          <iframe
            src={finalUrl}
            class="w-full h-full border-none"
            title={pageTitle}
          >
            Loading...
          </iframe>
        </section>
      )}
    </Layout>
  )
}

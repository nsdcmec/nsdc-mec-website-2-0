---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import ProjectsComponent from "../components/Projects.astro";

const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the projects page.");
}
---

<Layout title="Projects | NSDC MEC" links={data.links}>
  <ProjectsComponent projects={data.projects} />
</Layout>

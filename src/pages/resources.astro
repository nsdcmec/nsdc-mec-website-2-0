---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import Resource from "../components/Resources.astro";

const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the resources page.");
}
---

<Layout title="Resources | NSDC MEC" links={data.links}>
  <Resource resources={data.resources} client:load />
</Layout>

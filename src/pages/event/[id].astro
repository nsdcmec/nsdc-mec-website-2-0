---
import Layout from "../../layouts/Layout.astro";
import { dataService } from "../../lib/data-service";
import { parseEventDate } from "../../lib/date-utils";

const { id } = Astro.params;
const data = await dataService.getInitialData();

// Find by ID
const event = data.events.find((e) => e.id.toString() === id);

if (!event) {
  return Astro.redirect("/404");
}

const formattedDate = (() => {
  if (!event.date) return "TBA";
  const ts = parseEventDate(event.date);
  if (ts === 0) return event.date;
  return new Date(ts).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
})();

const meta = event.metadata || {};

const currentStatus = (() => {
  const ts = parseEventDate(event.date);
  const now = new Date().getTime();
  const oneYearAgo = now - 365 * 24 * 60 * 60 * 1000;

  if (event.metadata?.hero_config) {
    const start = new Date(event.metadata.hero_config.start_date).getTime();
    if (now < start) return "upcoming";
  }
  if (ts >= now) return "upcoming";
  if (ts >= oneYearAgo) return "recent";
  return "past";
})();
---

<Layout
  title={event.title}
  links={data.links}
  injections={data.config.injections}
  colors={data.config.colors}
>
    {/* Mobile Sticky Header */}
    <div class="lg:hidden sticky top-10 z-40 bg-bg-0/95 backdrop-blur-md border-b-2 border-fg-0 flex flex-col pt-4 pb-4 px-4 shadow-sm gap-3">
      <div class="flex items-center justify-between">
        <a href="/events" class="text-xs font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors">
          ← Back
        </a>
        {currentStatus === "past" && (
          <span class="text-xs font-bold uppercase tracking-widest text-fg-0 border border-fg-0 px-3 py-1 bg-bg-1">
            Event Ended
          </span>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tighter leading-tight break-words">
        {event.title}
      </h1>
      <div class="flex items-start gap-4 mt-1">
        <span class={`px-3 py-1 text-[10px] sm:text-xs font-bold uppercase tracking-[0.2em] border-2 border-fg-0 shrink-0 ${currentStatus === "upcoming" ? "bg-primary text-primary-fg border-primary" : "bg-bg-0 text-fg-0"}`}>
          {currentStatus}
        </span>
        <div class="flex flex-col gap-1 pt-[2px]">
          <span class="text-[10px] sm:text-xs font-mono font-bold text-fg-1 uppercase tracking-widest">
            {formattedDate}
          </span>
          {event.venue && (
            <span class="text-[10px] sm:text-xs font-mono font-bold text-fg-1 uppercase tracking-widest leading-tight">
              {event.venue}
            </span>
          )}
        </div>
      </div>
      {currentStatus !== "past" && event.link && (
        <a
          href={event.link}
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full py-3 mt-2 text-center text-xs font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
        >
          {event.button_text || "Register Now"}
        </a>
      )}
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 mt-8 lg:mt-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        {/* Sidebar Header (Date, Venue, Tags, Contact, Event Ended, Registration) */}
        <div class="hidden lg:flex lg:col-span-3 lg:sticky lg:top-10 space-y-12 pb-12 self-start flex-col">
          <a
            href="/events"
            class="hidden lg:inline-flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors mb-4"
          >
            ← Back to Events
          </a>

          <div class="lg:hidden mb-4">
            <a href="/events" class="text-[10px] font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors">
              ← Back
            </a>
          </div>

        <div class="space-y-6">
          <h1
            class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-[0.9] text-fg-0 break-words"
          >
            {event.title}
          </h1>

          <div class="flex flex-wrap gap-2 items-center">
            <span
              class={`px-2 py-1 text-[10px] font-bold uppercase tracking-[0.2em] border-2 border-fg-0 ${currentStatus === "upcoming" ? "bg-primary text-primary-fg border-primary" : "bg-bg-0 text-fg-0"}`}
            >
              {currentStatus}
            </span>
            {
              event.event_type && (
                <span class="text-[10px] font-bold uppercase tracking-[0.2em] bg-bg-2 text-fg-1 px-2 py-1 border-2 border-bg-2">
                  {event.event_type}
                </span>
              )
            }
          </div>

          <div class="flex flex-col gap-4 border-l-2 border-fg-0 pl-4 py-2">
            <div class="flex flex-col">
              <span
                class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-1"
              >
                Date
              </span>
              <span
                class="text-lg font-bold text-fg-0 uppercase tracking-tight"
              >
                {formattedDate}
              </span>
            </div>

            {
              event.venue && (
                <div class="flex flex-col">
                  <span class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-1">
                    Venue
                  </span>
                  <span class="text-lg font-bold text-fg-0 uppercase tracking-tight">
                    {event.venue}
                  </span>
                </div>
              )
            }
          </div>

          {
            event.tags && event.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-4">
                {event.tags.map((tag) => (
                  <span class="text-[10px] font-bold bg-bg-1 text-fg-1 px-2 py-1 uppercase tracking-widest border border-bg-2">
                    #{tag}
                  </span>
                ))}
              </div>
            )
          }

          {/* Registration / Contacts */}
          <div class="pt-8 border-t-2 border-fg-0/10 flex flex-col gap-8">
            {
              currentStatus === "past" && (
                <div class="flex flex-col border-2 border-fg-0 p-6 bg-bg-1">
                  <h3 class="text-xl font-bold uppercase tracking-tighter text-fg-0 mb-2">
                    Event Ended
                  </h3>
                  <p class="text-fg-1 text-xs font-sans mb-4">
                    This event has already concluded.
                  </p>
                  {event.report_url && (
                    <a
                      href={`/report/${event.id}`}
                      class="block w-full py-4 text-center text-sm font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
                    >
                      View Event Report
                    </a>
                  )}
                </div>
              )
            }

            {/* Registration Details */}
            <div class="flex flex-col">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-4 border-b-2 border-bg-2 pb-2">
                Registration details
              </h3>
              {
                meta.fees && meta.fees.length > 0 ? (
                  <div class="space-y-4 mb-6">
                    {meta.fees.map((fee) => (
                      <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-fg-1 uppercase tracking-widest mb-1">
                          {fee.label}
                        </span>
                        <span class="text-lg font-bold uppercase tracking-tighter text-fg-0">
                          {fee.amount}
                        </span>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="text-fg-1 text-xs italic mb-6">
                    No specific registration fees.
                  </p>
                )
              }

              {
                currentStatus !== "past" && event.link && (
                  <a
                    href={event.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block w-full py-4 text-center text-sm font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
                  >
                    {event.button_text || "Register Now"}
                  </a>
                )
              }
            </div>

            {/* Contacts */}
            {
              meta.contacts && meta.contacts.length > 0 && (
                <div class="flex flex-col border-t-2 border-bg-2 pt-8">
                  <h3 class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-4 border-b-2 border-bg-2 pb-2">
                    Contact
                  </h3>
                  <div class="space-y-4 text-sm">
                    {meta.contacts.map((contact) => (
                      <div class="flex flex-col">
                        <p class="font-bold uppercase tracking-tight text-fg-0 mb-1">
                          {contact.name}
                        </p>
                        {contact.role && (
                          <p class="text-[9px] font-bold uppercase tracking-widest text-fg-1 mb-2">
                            {contact.role}
                          </p>
                        )}
                        <div class="flex flex-col gap-1 mt-1">
                          {contact.phone && (
                            <a
                              href={`tel:${contact.phone}`}
                              class="group relative w-max text-xs text-fg-0 font-mono hover:text-primary transition-colors py-1"
                            >
                              <span>{contact.phone}</span>
                              <span class="absolute bottom-0 right-0 h-[1px] w-full bg-primary transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                            </a>
                          )}
                          {contact.email && (
                            <a
                              href={`mailto:${contact.email}`}
                              class="group relative w-max text-xs text-fg-0 font-mono hover:text-primary transition-colors py-1"
                            >
                              <span>{contact.email}</span>
                              <span class="absolute bottom-0 right-0 h-[1px] w-full bg-primary transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                            </a>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )
            }
          </div>
        </div>
      </div> {/* Fix missing closure for lg:col-span-4 */}

        {/* Main Content Area */}
        <div class="lg:col-span-9 flex flex-col gap-16 pb-16">
        
        {/* Mobile Info Display (shown only on mobile) */}
        {
          event.tags && event.tags.length > 0 && (
            <div class="lg:hidden flex flex-wrap gap-2 mb-2">
              {event.tags.map((tag) => (
                <span class="text-[10px] font-bold bg-bg-1 text-fg-1 px-2 py-1 uppercase tracking-widest border border-bg-2">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }

        {/* Main Image */}
        {event.image_url && (
          <figure class="w-full relative   mb-4  border-fg-0 flex justify-center">
            <img
              src={event.image_url}
              alt={event.title}
              class="max-w-full max-h-[70vh] object-contain"
            />
          </figure>
        )}

        {/* Description */}
        <section class="space-y-4 pt-4 lg:pt-0">
          <h2
            class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2"
          >
            About
          </h2>
          <div
            class="prose-content text-fg-1 font-sans text-lg md:text-xl leading-relaxed space-y-6 transition-colors duration-300"
          >
            {
              event.description?.split("\n").map((paragraph) => {
                if (!paragraph.trim()) return null;
                return <p>{paragraph}</p>;
              })
            }
          </div>
        </section>

        {/* Mobile Registration Details (Moved after About) */}
        <div class="lg:hidden flex flex-col gap-6 pt-4">
          {
            meta.fees && meta.fees.length > 0 && (
              <div class="flex flex-col gap-3 p-4 border-2 border-bg-2 bg-bg-1">
                <span class="text-[10px] font-bold uppercase tracking-widest text-fg-1 border-b border-bg-2 pb-2">Registration Fees</span>
                <div class="flex flex-col space-y-2">
                  {meta.fees.map((fee) => (
                    <div class="flex justify-between items-center text-sm font-bold uppercase tracking-tighter text-fg-0">
                      <span>{fee.label}</span>
                      <span class="text-primary">{fee.amount}</span>
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        {/* Rounds */}
        {
          meta.rounds && meta.rounds.length > 0 && (
            <section class="space-y-6 pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                Structure
              </h2>
              <div class="grid gap-6">
                {meta.rounds.map((round) => (
                  <div class="border-2 border-bg-2 p-6 md:p-8">
                    <div class="flex flex-col md:flex-row justify-between md:items-center gap-4 mb-4 pb-4 border-b-2 border-bg-2">
                      <h3 class="text-2xl font-bold uppercase tracking-tight text-fg-0">
                        {round.name}
                      </h3>
                      <span
                        class={`w-max px-3 py-1 text-[10px] uppercase font-bold tracking-[0.2em] border-2 ${round.format === "online" ? "border-primary text-primary" : "border-fg-0 text-fg-0"}`}
                      >
                        {round.format}
                      </span>
                    </div>
                    <p class="text-fg-1 text-lg leading-relaxed mb-6">
                      {round.desc}
                    </p>

                    {(round.objective || round.criteria || round.outcome) && (
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        {round.objective && (
                          <div class="flex flex-col gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Objective
                            </span>
                            <p class="text-sm text-fg-1">{round.objective}</p>
                          </div>
                        )}
                        {round.criteria && (
                          <div class="flex flex-col gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Criteria
                            </span>
                            <p class="text-sm text-fg-1">{round.criteria}</p>
                          </div>
                        )}
                        {round.outcome && (
                          <div class="flex flex-col gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Outcome
                            </span>
                            <p class="text-sm text-fg-1">{round.outcome}</p>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )
        }

        {/* Prizes */}
        {
          meta.prizes && meta.prizes.length > 0 && (
            <section class="space-y-6 pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                Prizes & Rewards
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {meta.prizes
                  .sort((a, b) => a.priority - b.priority)
                  .map((prize) => {
                    return (
                      <div class="border-2 border-bg-2 p-6 md:p-8 flex flex-col justify-between">
                        <div class="mb-8">
                          <h4 class="text-sm font-bold uppercase tracking-widest text-fg-1 mb-2">
                            {prize.title}
                          </h4>
                          <p
                            class={`text-4xl lg:text-5xl font-black uppercase tracking-tighter ${prize.position === 1 ? "text-primary" : "text-fg-0"} leading-none`}
                          >
                            {prize.reward}
                          </p>
                        </div>
                        {prize.desc && (
                          <p class="text-sm text-fg-1 pt-4 border-t-2 border-bg-2">
                            {prize.desc}
                          </p>
                        )}
                      </div>
                    );
                  })}
              </div>
            </section>
          )
        }

        {/* Collaborators */}
        {
          meta.collaborators && meta.collaborators.length > 0 && (
            <section class="space-y-6 pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                In Collaboration With
              </h2>
              <div class="flex flex-wrap gap-12 items-center">
                {meta.collaborators.map((collab) => (
                  <div class="flex items-center gap-4">
                    {collab.img && (
                      <img
                        src={collab.img}
                        alt={collab.name}
                        class="h-16 w-auto object-contain"
                      />
                    )}
                    {!collab.img && (
                      <span class="font-bold uppercase tracking-widest text-fg-0">
                        {collab.name}
                      </span>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )
        }

        {/* Contacts (Mobile Only - moved to bottom) */}
        <div class="lg:hidden flex flex-col gap-6 pt-8 mt-8 border-t-4 border-fg-0">
          {
            meta.contacts && meta.contacts.length > 0 && (
              <div class="flex flex-col gap-3 pt-4 border-t-2 border-fg-0/10">
                <span class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-1 border-b-2 border-bg-2 pb-2">Contact Details</span>
                {meta.contacts.map((contact) => (
                  <div class="flex flex-col mt-2">
                    <span class="font-bold uppercase tracking-tighter text-fg-0 text-sm">{contact.name}</span>
                    {contact.role && <span class="text-[9px] font-bold uppercase tracking-widest text-fg-1">{contact.role}</span>}
                    <div class="flex flex-wrap gap-4 mt-1">
                      {contact.phone && <a href={`tel:${contact.phone}`} class="text-xs font-mono text-primary hover:underline py-1 w-max">{contact.phone}</a>}
                      {contact.email && <a href={`mailto:${contact.email}`} class="text-xs font-mono text-primary hover:underline py-1 w-max">{contact.email}</a>}
                    </div>
                  </div>
                ))}
              </div>
            )
          }
        </div>

        {/* End of Main Content Area */}
      </div>
    </div>

    {
      event.custom_html && (
        <div
          class="mt-24 border-t-4 border-fg-0 pt-16"
          set:html={event.custom_html}
        />
      )
    }
  </div>
</Layout>

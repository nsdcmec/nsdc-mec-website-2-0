---
import Layout from "../../layouts/Layout.astro";
import { dataService } from "../../lib/data-service";
import { parseEventDate, formatDate } from "../../lib/date-utils";
import { slugify } from "../../lib/slugify";
import { getTarget, getRel } from "../../lib/link-utils";
import TeamCarousel from "../../components/TeamCarousel";

const { slug } = Astro.params;
const data = await dataService.getInitialData();

// Find by Slug (primary) or ID (fallback)
const event = data.events.find(
  (e) => slugify(e.title) === slug || e.id.toString() === slug,
);

if (!event) {
  return Astro.redirect("/404");
}

const eventTs = parseEventDate(event.date);
const formattedDate = formatDate(event.date);

const formattedTime = (() => {
  if (!event.date || (!event.date.includes(":") && !event.date.includes("T")))
    return null;
  const ts = eventTs;
  if (ts === 0) return null;
  return new Date(ts).toLocaleTimeString("en-US", {
    hour: "numeric",
    minute: "2-digit",
    hour12: true,
  });
})();

const meta = event.metadata || {};

const metaDescription = event.description
  ? event.description.length > 160
    ? event.description.substring(0, 157) + "..."
    : event.description
  : undefined;

const currentStatus = (() => {
  const ts = eventTs;
  const now = new Date().getTime();
  const oneYearAgo = now - 365 * 24 * 60 * 60 * 1000;

  const hero = meta.hero_config;
  const startTs = hero?.start_date ? parseEventDate(hero.start_date) : ts;
  const endTs = hero?.end_date ? parseEventDate(hero.end_date) : 0;

  if (endTs > 0 && now >= startTs && now <= endTs) return "happening";
  if (startTs >= now) return "upcoming";
  if (ts >= oneYearAgo) return "recent";
  return "past";
  })();
  ---
<Layout
  title={event.title}
  links={data.links}
  injections={data.config.injections}
  colors={data.config.colors}
  description={metaDescription}
  image={event.image_url}
  defaultTheme={data.config.theme}
>
    {/* Mobile Sticky Header */}
    <div class="md:hidden sticky top-10 z-40 bg-bg-0/95 backdrop-blur-md border-b-2 border-fg-0 flex flex-col pt-3 pb-3 px-4 shadow-sm gap-2">
      <div class="flex items-center justify-between">
        <a href="/events" class="group relative w-fit text-xs font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors">
          <span>← Back</span>
          <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
        </a>
        {currentStatus === "past" && (
          <span class="text-xs font-bold uppercase tracking-widest text-fg-0 border border-fg-0 px-3 py-1 bg-bg-1">
            Event Ended
          </span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-black uppercase tracking-tighter leading-[1.1] break-words">
        {event.title}
      </h1>
      <div class="flex items-start gap-3 mt-0.5">
        <span class={`px-2 py-1 text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] border-2 border-fg-0 shrink-0 ${["upcoming", "happening"].includes(currentStatus) ? "bg-primary text-primary-fg border-primary" : "bg-bg-0 text-fg-0"}`}>
          {currentStatus === "happening" ? "Happening Now" : currentStatus}
        </span>
        <div class="flex flex-col gap-0.5 pt-[1px]">
        <div>
          {formattedDate && (
            <span class="text-[10px] md:text-xs font-mono font-bold text-fg-1 uppercase tracking-widest">
              {formattedDate}
            </span>
          )}
{
              formattedTime && (
<span class="client-time text-[10px] md:text-xs font-mono font-bold text-fg-1 uppercase tracking-widest" data-time-ts={eventTs}>
            , {formattedTime}
          </span>
                
              )
            }
</div>
          {event.venue && (
            <span class="text-[10px] md:text-xs font-mono font-bold text-fg-1 uppercase tracking-widest leading-tight">
              {event.venue}
            </span>
          )}
        </div>
      </div>
      {event.report_url ? (
        <a
          href={`/report/${slugify(event.title)}`}
          class="block w-full py-2.5 mt-1 text-center text-xs font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
        >
          View Event Report
        </a>
      ) : (
        currentStatus !== "past" && event.link && (
          <a
            href={event.link}
            target={getTarget(event.link)}
            rel={getRel(event.link)}
            class="block w-full py-2.5 mt-1 text-center text-xs font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
          >
            {event.button_text || "Register Now"}
          </a>
        )
      )}
      {
        meta.extra_links && meta.extra_links.length > 0 && (
          <div class="flex flex-col gap-1.5">
            {meta.extra_links.map((extra) => (
              <a
                href={extra.link}
                target={getTarget(extra.link)}
                rel={getRel(extra.link)}
                class="block w-full py-2 text-center text-[10px] font-bold uppercase tracking-widest border-2 border-fg-0 text-fg-0 hover:bg-fg-0 hover:text-bg-0 transition-all"
              >
                {extra.title}
              </a>
            ))}
          </div>
        )
      }
    </div>

    <div class="container mx-auto px-4 md:px-6  mt-6 md:mt-16">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
        {/* Sidebar Header (Date, Venue, Tags, Contact, Event Ended, Registration) */}
        <div class="hidden md:flex md:col-span-3 md:sticky md:top-10 space-y-8 md:space-y-10 pb-10 self-start flex-col">
          <a
            href="/events"
            class="group relative w-fit hidden md:inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors mb-2"
          >
            <span>← Back to Events</span>
            <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
          </a>

          <div class="md:hidden mb-2">
            <a href="/events" class="group relative w-fit text-xs font-bold uppercase tracking-widest text-fg-1 hover:text-fg-0 transition-colors">
              <span>← Back</span>
              <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
            </a>
          </div>

        <div class="space-y-4 md:space-y-6">
          <h1
            class="text-4xl md:text-5xl  font-black uppercase tracking-tighter leading-[0.9] text-fg-0 break-words"
          >
            {event.title}
          </h1>

          <div class="flex flex-wrap gap-2 items-center">
            <span
              class={`px-2 py-1 text-[10px] font-bold uppercase tracking-[0.2em] border-2 border-fg-0 ${["upcoming", "happening"].includes(currentStatus) ? "bg-primary text-primary-fg border-primary" : "bg-bg-0 text-fg-0"}`}
            >
              {currentStatus === "happening" ? "Happening Now" : currentStatus}
            </span>
            {
              event.event_type && (
                <span class="text-[10px] font-bold uppercase tracking-[0.2em] bg-bg-2 text-fg-1 px-2 py-1 border-2 border-bg-2">
                  {event.event_type}
                </span>
              )
            }
          </div>

          <div class="flex flex-col gap-3 md:gap-4 border-l-2 border-fg-0 pl-4 py-1 md:py-2">
            {formattedDate && (
              <div class="flex flex-col">
                <span
                  class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-0.5 md:mb-1"
                >
                  Date
                </span>
                <span
                  class=" font-bold text-fg-0 uppercase tracking-tight"
                >
                  {formattedDate}
                </span>
              </div>
            )}
{
              formattedTime && (
<div class="flex flex-col">
              <span
                class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-0.5 md:mb-1"
              >
               Time 
              </span>
              <span
                class="client-time font-bold text-fg-0 uppercase tracking-tight" data-time-ts={eventTs}
              >
                {formattedTime}
              </span>
            </div>
              )
            }

            {
              event.venue && (
                <div class="flex flex-col">
                  <span class="text-[9px] font-mono font-bold text-fg-1 uppercase tracking-widest mb-0.5 md:mb-1">
                    Venue
                  </span>
                  <span class=" font-bold text-fg-0 uppercase tracking-tight">
                    {event.venue}
                  </span>
                </div>
              )
            }
          </div>

          {
            event.tags && event.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-2 md:pt-4">
                {event.tags.map((tag) => (
                  <span class="text-[10px] font-bold bg-bg-1 text-fg-1 px-2 py-0.5 md:py-1 uppercase tracking-widest border border-bg-2">
                    #{tag}
                  </span>
                ))}
              </div>
            )
          }

          {/* Registration / Contacts */}
          <div class="pt-6 md:pt-8 border-t-2 border-fg-0/10 flex flex-col gap-6 md:gap-8">
            {
              (currentStatus === "past" || event.report_url) && (
                <div class="flex flex-col border-2 border-fg-0 p-4 md:p-6 bg-bg-1">
                  <h3 class=" font-bold uppercase tracking-tighter text-fg-0 mb-1 md:mb-2">
                    {event.report_url ? "Event Concluded" : "Event Ended"}
                  </h3>
                  <p class="text-fg-1 text-xs font-sans mb-3 md:mb-4">
                    {event.report_url ? "The report for this event is now available." : "This event has already concluded."}
                  </p>
                  {event.report_url && (
                    <a
                      href={`/report/${slugify(event.title)}`}
                      class="block w-full py-3 md:py-4 text-center text-sm font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0"
                    >
                      View Event Report
                    </a>
                  )}
                </div>
              )
            }

            {/* Registration Details */}
            <div class="flex flex-col">
              <h3 class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-3 md:mb-4 border-b-2 border-bg-2 pb-2">
                Registration details
              </h3>
              {
                meta.fees && meta.fees.length > 0 ? (
                  <div class="space-y-2 md:space-y-3 mb-2 md:mb-3">
                    {meta.fees.map((fee) => (
                      <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-fg-1 uppercase tracking-widest mb-0.5">
                          {fee.label}
                        </span>
                        <span class=" font-semibold  tracking-tighter text-fg-0">
                          {fee.amount}
                        </span>
                        {fee.condition && (
                          <span class="text-[9px] text-fg-1 font-sans mt-1 leading-tight italic">
                            {fee.condition}
                          </span>
                        )}
                      </div>
                    ))}
                  </div>
                ) : (
                  <p class="text-fg-1 text-xs italic mb-4 md:mb-6">
                    No specific registration fees.
                  </p>
                )
              }

              {
                !event.report_url && currentStatus !== "past" && event.link && (
                  <a
                    href={event.link}
                    target={getTarget(event.link)}
                    rel={getRel(event.link)}
                    class="block w-full py-3 md:py-4 text-center text-sm font-bold uppercase tracking-widest bg-primary text-primary-fg hover:bg-fg-0 hover:text-bg-0 transition-colors border-2 border-primary hover:border-fg-0 mb-4"
                  >
                    {event.button_text || "Register Now"}
                  </a>
                )
              }

              {/* Extra Links */}
              {
                meta.extra_links && meta.extra_links.length > 0 && (
                  <div class="flex flex-col gap-2">
                    {meta.extra_links.map((extra) => (
                      <a
                        href={extra.link}
                        target={getTarget(extra.link)}
                        rel={getRel(extra.link)}
                        class="block w-full py-2.5 text-center text-xs font-bold uppercase tracking-widest border-2 border-fg-0 text-fg-0 hover:bg-fg-0 hover:text-bg-0 transition-all"
                      >
                        {extra.title}
                      </a>
                    ))}
                  </div>
                )
              }
            </div>

            {/* Contacts */}
            {
              meta.contacts && meta.contacts.length > 0 && (
                <div class="flex flex-col  border-bg-2 pt-2">
                  <h3 class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-3 md:mb-4 border-b-2 border-bg-2 pb-2">
                    Contact
                  </h3>
                  <div class="space-y-3 md:space-y-4 text-sm">
                    {meta.contacts.map((contact) => (
                      <div class="flex flex-col">
                        <p class="font-bold uppercase tracking-tight text-fg-0 mb-0.5">
                          {contact.name}
                        </p>
                        {contact.role && (
                          <p class="text-[9px] font-bold uppercase tracking-widest text-fg-1 mb-1 md:mb-2">
                            {contact.role}
                          </p>
                        )}
                        <div class="flex flex-col gap-0.5 mt-0.5">
                          {contact.phone && (
                            <a
                              href={`tel:${contact.phone}`}
                              class="group relative w-max text-xs text-fg-0 font-mono hover:text-primary transition-colors py-0.5"
                            >
                              <span>{contact.phone}</span>
                              <span class="absolute bottom-0 right-0 h-[1px] w-full bg-primary transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                            </a>
                          )}
                          {contact.email && (
                            <a
                              href={`mailto:${contact.email}`}
                              class="group relative w-max text-xs text-fg-0 font-mono hover:text-primary transition-colors py-0.5"
                            >
                              <span>{contact.email}</span>
                              <span class="absolute bottom-0 right-0 h-[1px] w-full bg-primary transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                            </a>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )
            }
          </div>
        </div>
      </div> {/* Fix missing closure for md:col-span-4 */}

        {/* Main Content Area */}
        <div class="md:col-span-9 flex flex-col gap-8 md:gap-12 pb-12 md:pb-16">
        
        {/* Mobile Info Display (shown only on mobile) */}
        {
          event.tags && event.tags.length > 0 && (
            <div class="md:hidden flex flex-wrap gap-2 mb-2">
              {event.tags.map((tag) => (
                <span class="text-[10px] font-bold bg-bg-1 text-fg-1 px-2 py-0.5 uppercase tracking-widest border border-bg-2">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }

        {/* Main Image */}
        {event.image_url && (
          <figure class="w-full relative   mb-2 md:mb-4  border-fg-0 flex justify-center">
            <img
              src={event.image_url}
              alt={event.title}
              class="max-w-full max-h-[70vh] object-contain"
            />
          </figure>
        )}

        {/* Description */}
        <section class="space-y-4 pt-2 md:pt-0">
          <h2
            class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2"
          >
            About
          </h2>
          <div
            class="prose-content text-fg-1 font-sans text-sm md:text-base  leading-relaxed space-y-4 md:space-y-6 transition-colors duration-300"
          >
            {
              event.description?.split("\n").map((paragraph) => {
                if (!paragraph.trim()) return null;
                return <p>{paragraph}</p>;
              })
            }
          </div>
        </section>
{
      meta.highlights && meta.highlights.length > 0 && (
<section class="space-y-4 pt-2 md:pt-0">
          <h2
            class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2"
          >
            Highlights
          </h2>
          <TeamCarousel
          items={meta.highlights}
          title="EVENT HIGHLIGHTS"
          subtitle={event.title}
          showExploreLink={false}
          client:load
        />

        </section>

              )
    }


        {/* Mobile Registration Details (Moved after About) */}
        <div class="md:hidden flex flex-col gap-4 pt-2">
          {
            meta.fees && meta.fees.length > 0 && (
              <div class="flex flex-col gap-2 p-3 border-2 border-bg-2 bg-bg-1">
                <span class="text-[10px] font-bold uppercase tracking-widest text-fg-1 border-b border-bg-2 pb-1.5">Registration Fees</span>
                <div class="flex flex-col space-y-1.5">
                  {meta.fees.map((fee) => (
                    <div class="flex flex-col gap-1">
                      <div class="flex justify-between items-center text-sm font-bold uppercase tracking-tighter text-fg-0">
                        <span>{fee.label}</span>
                        <span class="text-primary">{fee.amount}</span>
                      </div>
                      {fee.condition && (
                        <span class="text-[10px] text-fg-1 font-sans leading-tight italic">
                          {fee.condition}
                        </span>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        {/* Rounds */}
        {
          meta.rounds && meta.rounds.length > 0 && (
            <section class="space-y-4 md:space-y-6 pt-6 md:pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                Structure
              </h2>
              <div class="grid gap-4">
                {meta.rounds
                  .sort((a, b) => a.priority - b.priority)
                  .map((round) => (
                  <div class="border-2 border-bg-2 p-4 md:p-6">
                    <div class="flex flex-col md:flex-row justify-between md:items-center gap-2 md:gap-4 mb-3 md:mb-4 pb-3 md:pb-4 border-b-2 border-bg-2">
                      <h3 class="text-xl font-bold uppercase tracking-tight text-fg-0">
                        {round.name}
                      </h3>
                      <span
                        class={`w-max px-2 md:px-3 py-0.5 md:py-1 text-[10px] uppercase font-bold tracking-[0.2em] border-2 ${round.format === "online" ? "border-primary text-primary" : "border-fg-0 text-fg-0"}`}
                      >
                        {round.format}
                      </span>
                    </div>
                    <p class="text-fg-1 text-sm md:text-base leading-relaxed mb-4 md:mb-6">
                      {round.desc}
                    </p>

                    {(round.objective || round.criteria || round.outcome) && (
                      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                        {round.objective && (
                          <div class="flex flex-col gap-1.5 md:gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Objective
                            </span>
                            <p class="text-xs md:text-sm text-fg-1">{round.objective}</p>
                          </div>
                        )}
                        {round.criteria && (
                          <div class="flex flex-col gap-1.5 md:gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Criteria
                            </span>
                            <p class="text-xs md:text-sm text-fg-1">{round.criteria}</p>
                          </div>
                        )}
                        {round.outcome && (
                          <div class="flex flex-col gap-1.5 md:gap-2">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-fg-0 border-b border-fg-0/10 pb-1">
                              Outcome
                            </span>
                            <p class="text-xs md:text-sm text-fg-1">{round.outcome}</p>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )
        }

        {/* Prizes */}
        {
          meta.prizes && meta.prizes.length > 0 && (
            <section class="space-y-4 md:space-y-6 pt-6 md:pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                Prizes & Rewards
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                {meta.prizes
                  .sort((a, b) => a.priority - b.priority)
                  .map((prize) => {
                    return (
                      <div class="border-2 border-bg-2 p-4 md:p-6 flex flex-col justify-between">
                        <div class="mb-6 md:mb-8">
                          <h4 class="text-sm font-bold uppercase tracking-widest text-fg-1 mb-1 md:mb-2">
                            {prize.title}
                          </h4>
                          <p
                            class={`text-3xl md:text-5xl font-black uppercase tracking-tighter ${prize.position === 1 ? "text-primary" : "text-fg-0"} leading-none`}
                          >
                            {prize.reward}
                          </p>
                        </div>
                        {prize.desc && (
                          <p class="text-xs md:text-sm text-fg-1 pt-3 md:pt-4 border-t-2 border-bg-2">
                            {prize.desc}
                          </p>
                        )}
                      </div>
                    );
                  })}
              </div>
            </section>
          )
        }

        {/* Collaborators */}
        {
          meta.collaborators && meta.collaborators.length > 0 && (
            <section class="space-y-4 md:space-y-6 pt-6 md:pt-8">
              <h2 class="text-2xl font-bold uppercase tracking-tighter text-fg-0 border-b-2 border-fg-0 pb-2">
                In Collaboration With
              </h2>
              <div class="flex flex-wrap gap-x-12 gap-y-8 items-start">
                {meta.collaborators.map((collab) => {
                  const Container = collab.link ? 'a' : 'div';
                  return (
                    <Container
                      href={collab.link}
                      target={getTarget(collab.link)}
                      rel={getRel(collab.link)}
                      class="flex flex-col gap-3"
                    >
                      {collab.img && (
                        <img
                          src={collab.img}
                          alt={collab.name}
                          class="h-12 md:h-16 w-auto object-contain object-left"
                        />
                      )}
                      <div class="flex flex-col">
                        <span class="font-bold uppercase tracking-widest text-fg-0 text-sm">
                          {collab.name}
                        </span>
                        {collab.desc && (
                          <p class="text-[11px] text-fg-1 leading-tight mt-1 max-w-[180px]">
                            {collab.desc}
                          </p>
                        )}
                      </div>
                    </Container>
                  );
                })}
              </div>
            </section>
          )
        }

        {/* Contacts (Mobile Only - moved to bottom) */}
        <div class="md:hidden flex flex-col gap-4 pt-6 mt-6 border-t-4 border-fg-0">
          {
            meta.contacts && meta.contacts.length > 0 && (
              <div class="flex flex-col gap-2.5 pt-3 border-t-2 border-fg-0/10">
                <span class="text-[10px] font-bold uppercase tracking-widest text-fg-1 mb-0.5 border-b-2 border-bg-2 pb-1.5">Contact Details</span>
                {meta.contacts.map((contact) => (
                  <div class="flex flex-col mt-1.5">
                    <span class="font-bold uppercase tracking-tighter text-fg-0 text-sm">{contact.name}</span>
                    {contact.role && <span class="text-[9px] font-bold uppercase tracking-widest text-fg-1">{contact.role}</span>}
                    <div class="flex flex-wrap gap-3 mt-0.5">
                      {contact.phone && (
                        <a
                          href={`tel:${contact.phone}`}
                          class="group relative w-max text-[11px] font-mono text-primary hover:text-fg-0 transition-colors py-0.5"
                        >
                          <span>{contact.phone}</span>
                          <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                        </a>
                      )}
                      {contact.email && (
                        <a
                          href={`mailto:${contact.email}`}
                          class="group relative w-max text-[11px] font-mono text-primary hover:text-fg-0 transition-colors py-0.5"
                        >
                          <span>{contact.email}</span>
                          <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )
          }
        </div>


        {/* End of Main Content Area */}
      </div>
    </div>

    
    {
      event.custom_html && (
        <div
          class="mt-12 md:mt-24 border-t-4 border-fg-0 pt-8 md:pt-16"
          set:html={event.custom_html}
        />
      )
    }
  </div>

  <script is:inline>
    // Adjust event times to local timezone
    document.querySelectorAll('.client-time').forEach((el) => {
      const ts = parseInt(el.getAttribute('data-time-ts'));
      if (ts && !isNaN(ts)) {
        const localTime = new Date(ts).toLocaleTimeString('en-US', {
          hour: 'numeric',
          minute: '2-digit',
          hour12: true,
        });
        // Keep the comma if it exists in the original text (for mobile)
        const hasComma = el.textContent.trim().startsWith(',');
        el.textContent = (hasComma ? ', ' : '') + localTime;
      }
    });
  </script>
</Layout>

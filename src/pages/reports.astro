---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import ReportComponent from "../components/Reports.astro";

const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the reports page.");
}

const reports = data.events
  .filter((e) => e.status === 'past' && e.report_url)
  .map((e) => ({
    id: e.id.toString(),
    relation: e.id.toString(), // Using id as fallback for relation
    date: e.date || "",
    title: e.title,
    desc: e.description || "",
    img: e.image_url || "",
  }));
---

<Layout title="Reports | NSDC MEC" links={data.links} injections={data.config.injections} colors={data.config.colors}>
  <ReportComponent reports={reports} />
</Layout>
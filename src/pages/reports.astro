---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";
import ReportComponent from "../components/Reports.astro";
import { parseEventDate } from "../lib/date-utils";
import { slugify } from "../lib/slugify";

const data = await dataService.getInitialData();

if (!data) {
  throw new Error("Failed to load data for the reports page.");
}

const now = new Date().getTime();
const reports = data.events
  .filter((e) => {
    const eventDate = parseEventDate(e.date);
    return eventDate > 0 && eventDate < now && e.report_url;
  })
  .sort((a, b) => {
    const dateA = parseEventDate(a.date);
    const dateB = parseEventDate(b.date);
    return dateB - dateA;
  })
  .map((e) => ({
    id: slugify(e.title),
    relation: slugify(e.title),
    date: e.date || "",
    title: e.title,
    desc: e.description || "",
    img: e.image_url || "",
  }));
---

<Layout
  title="Reports | NSDC MEC"
  links={data.links}
  injections={data.config.injections}
  colors={data.config.colors}
  description="Reports from NSDC MEC Events"
  defaultTheme={data.config.theme}
>
  <ReportComponent reports={reports} />
</Layout>


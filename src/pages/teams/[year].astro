---
import Layout from "../../layouts/Layout.astro";
import TeamList from "../../components/TeamList";
import { dataService } from "../../lib/data-service";
import type { TeamYear } from "../../types";

const data = await dataService.getInitialData();
const { year } = Astro.params;
const yearNum = parseInt(year || "0");

const currentTeam = data.teams.find((t: TeamYear) => t.year === yearNum);

if (!currentTeam) {
  const latest = data.teams[0]?.year;
  if (latest) return Astro.redirect(`/teams/${latest}`);
  return Astro.redirect("/404");
}

const allYears = data.teams.map((t: TeamYear) => ({
  id: t.year,
  title: t.year.toString(),
}));
---

<Layout
  title={`${currentTeam.year} Team | NSDC MEC`}
  links={data.links}
  injections={data.config.injections}
>
  <TeamList
    members={currentTeam.members}
    allYears={allYears}
    currentYear={yearNum}
    client:load
  />
</Layout>

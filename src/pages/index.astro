---
import Layout from "../layouts/Layout.astro";
import { dataService } from "../lib/data-service";

import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import EventIsland from "../components/EventIsland";
import TeamPreview from "../components/TeamPreview.astro";

const data = await dataService.getInitialData();
if (!data) {
  throw new Error("Failed to load initial data for the homepage.");
}
---

<Layout title="NSDC MEC" links={data.links}>
  <Hero content={data.heroContent} announcements={data.announcements} />
  <About content={data.about} />

  <EventIsland events={data.events} client:load />
  <TeamPreview imageUrl={data.teamsPreview.src} />
</Layout>

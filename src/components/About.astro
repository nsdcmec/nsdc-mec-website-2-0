---
import type { AboutContent } from "../types";

interface Props {
  content: AboutContent;
}

const { content } = Astro.props;
---

<section id="about" class="py-16 lg:py-24 bg-[#FAF9F6]">
  <div class="px-4">
    <div class="grid lg:grid-cols-4 gap-x-12">
      <div class="lg:col-span-1 mb-8 lg:mb-0">
        <span
          class="text-sm font-medium tracking-wide text-gray-700 lg:sticky lg:top-24"
        >
          Our Mission
        </span>
      </div>

      <div class="lg:col-span-3">
        <div class="text-2xl md:text-3xl text-gray-800 leading-relaxed space-y-10">
          <p>{content.title}</p>
          {content.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>
  </div>
</section>

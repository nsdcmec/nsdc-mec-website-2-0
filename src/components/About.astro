---
import type { AboutConfig, SiteData } from "../types";
import { parseEventDate } from "../lib/date-utils";

interface Props {
  content: AboutConfig;
  siteData?: SiteData;
}

const { content, siteData } = Astro.props;

// 1. Members Calculation
const currentTeam =
  siteData?.teams && siteData.teams.length > 0 ? siteData.teams[0] : null;
const coreMembersCount = currentTeam?.members?.length || 0;
const teamImages =
  currentTeam?.members
    ?.slice(0, 4)
    .map((m) => m.image_url)
    .filter(Boolean) || [];

// Calculate Lifetime Members (Distinct Names across all years)
const allTeamMembers = siteData?.teams?.flatMap((t) => t.members) || [];
const uniqueMemberNames = new Set(
  allTeamMembers.map((m) => m.name.toLowerCase().trim()),
);
const lifetimeMembersCount = uniqueMemberNames.size;

// 2. Events & Recent Info
const allEvents = siteData?.events || [];
const now = new Date().getTime();
const conductedEvents = allEvents.filter((e) => {
  const eventDate = parseEventDate(e.date);
  return eventDate > 0 && eventDate < now;
});
const eventsCount = conductedEvents.length;

// 3. Publications
const researchProjectCount = siteData?.resources
  ? siteData.resources.filter(
      (r) =>
        r.resource_type?.toLowerCase() === "research" ||
        r.resource_type?.toLowerCase() === "project" ||
        r.resource_type?.toLowerCase() === "publication",
    ).length
  : 0;

// 4. Config Data
const establishedYear = content.established_year;
const yearsActive = establishedYear
  ? new Date().getFullYear() - establishedYear
  : 0;

// Strip any existing '+' signs from the DB string so we don't end up with "1500++"
const cleanParticipantsCount =
  content.total_participants?.replace(/\++$/, "") || "0";

const title = content.title;
const subtitle = content.subtitle;
---

<section id="about" class="bg-bg-0 pt-16">
  <div class="container mx-auto px-2">
    <div class="flex flex-col gap-4">
      {/* Header Section */}
      <div>
        <h2 class="text-5xl font-black font-sans text-fg-0">
          {title}
        </h2>
        {
          subtitle && (
            <p class="text-xl md:text-2xl text-fg-1 mt-4 font-medium ">
              {subtitle}
            </p>
          )
        }
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-6 items-start">
        <div class="flex flex-col gap-4 md:gap-6">
          {
            content.desc_main && (
              <div class="text-base text-fg-1 text-justify break-normal">
                <p>{content.desc_main}</p>
              </div>
            )
          }

          {
            content.nbdc && content.nbdc.title && (
              <div class="border border-bg-2 bg-bg-1 p-2 md:p-4 flex flex-col gap-2 md:gap-4 ">
                <div class="flex items-center gap-4 ">
                  {content.nbdc.img && (
                    <div class="w-12 h-12 border border-bg-2    flex items-center justify-center p-2">
                      <img
                        src={content.nbdc.img}
                        alt=""
                        class="w-full h-full object-contain  "
                      />
                    </div>
                  )}
                  <h4 class=" md:text-lg font-bold text-fg-0    ">
                    {content.nbdc.title}
                  </h4>
                </div>
                <p class="text-sm text-fg-1 ">{content.nbdc.desc}</p>
              </div>
            )
          }
        </div>

        <div class="flex flex-col gap-4 md:gap-6">
          {
            content.chairperson && content.chairperson.quote && (
              <div class="bg-fg-0 text-bg-0 p-4 md:p-6 flex flex-col gap-4 md:gap-6">
                <p class="text-sm md:text-base font-serif italic    ">
                  "{content.chairperson.quote}"
                </p>
                <div class="flex items-center gap-4 mt-auto">
                  {content.chairperson.img && (
                    <img
                      src={content.chairperson.img}
                      alt={content.chairperson.name}
                      class="w-10 h-10 rounded-full object-cover border border-bg-0/20"
                    />
                  )}
                  <div class="flex flex-col">
                    {content.chairperson.name && (
                      <span class=" font-bold   tracking-widest uppercase">
                        {content.chairperson.name}
                      </span>
                    )}
                    {content.chairperson.role && (
                      <span class="text-xs opacity-90    tracking-widest uppercase">
                        {content.chairperson.role}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            )
          }

          <div class="border border-bg-2 bg-bg-1 flex flex-col">
            {
              establishedYear && (
                <div class="p-4 border-b border-bg-2 flex items-center justify-between">
                  <div class="flex flex-col">
                    <span class="text-4xl font-black font-sans text-fg-0 tracking-tighter leading-none mb-1">
                      {yearsActive}+
                    </span>
                    <span class="text-xs font-bold uppercase tracking-widest text-fg-1">
                      Years Active
                    </span>
                  </div>
                </div>
              )
            }

            <div class="grid grid-cols-3 md:grid-cols-1">
              <div
                class="p-2 md:p-4 border-r lg:border-r-0 lg:border-b border-bg-2 flex flex-col justify-center"
              >
                <span
                  class="text-2xl md:text-4xl font-black font-sans text-fg-0 tracking-tighter leading-none mb-1"
                >
                  {eventsCount}
                </span>
                <span
                  class="text-xs font-bold uppercase tracking-widest text-fg-1 break-words"
                >
                  Events
                </span>
              </div>

              <div
                class="p-2 md:p-4 border-r lg:border-r-0 lg:border-b border-bg-2 flex flex-col justify-center"
              >
                <span
                  class="text-2xl md:text-4xl font-black font-sans text-fg-0 tracking-tighter leading-none mb-1"
                >
                  {researchProjectCount}
                </span>
                <span
                  class="text-xs font-bold uppercase tracking-widest text-fg-1 break-words"
                >
                  Publications
                </span>
              </div>

              <div class="p-2 md:p-4 flex flex-col justify-center">
                <span
                  class="text-2xl md:text-4xl font-black font-sans text-fg-0 tracking-tighter leading-none mb-1"
                >
                  {cleanParticipantsCount}+
                </span>
                <span
                  class="text-xs font-bold uppercase tracking-widest text-fg-1 break-words"
                >
                  Reached
                </span>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-4 md:gap-6">
          {
            content.impact && (
              <div class="border border-bg-2 bg-bg-1 p-4 gap-2 md:gap-4 md:p-6 flex flex-col justify-between">
                <h1 class="text-fg-0  font-bold uppercase tracking-widest leading-relaxed  border-b border-bg-2 ">
                  {content.impact.title}
                </h1>
                <p class="text-fg-1 text-xs font-sans leading-relaxed ">
                  {content.impact.desc}
                </p>
                <div class="flex items-end justify-between">
                  <div class="flex flex-col gap-3">
                    {teamImages.length > 0 && (
                      <div class="flex -space-x-2 mb-1">
                        {teamImages.map((img) => (
                          <img
                            src={img}
                            alt=""
                            class="w-8 h-8 rounded-full border-2 border-bg-1 object-cover bg-bg-2"
                          />
                        ))}
                      </div>
                    )}
                    <div class="flex flex-col">
                      <span class="text-3xl font-black text-fg-0 leading-none mb-1">
                        {coreMembersCount}
                      </span>
                      <span class="text-xs font-bold uppercase tracking-widest text-fg-1">
                        Core Members
                      </span>
                    </div>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-4xl font-black text-primary leading-none tracking-tighter mb-1">
                      {lifetimeMembersCount}+
                    </span>
                    <span class="text-xs font-bold uppercase tracking-widest text-fg-1 text-right">
                      Lifetime Members
                    </span>
                  </div>
                </div>
              </div>
            )
          }
          {
            content.external_testimonial &&
              content.external_testimonial.quote && (
                <div class="border border-bg-2 bg-bg-1 p-4 md:p-6 flex flex-col">
                  <p class="text-sm text-fg-1 italic leading-relaxed mb-4">
                    "{content.external_testimonial.quote}"
                  </p>
                  <div class="flex items-center gap-4 mt-auto">
                    {content.external_testimonial.img && (
                      <img
                        src={content.external_testimonial.img}
                        alt={content.external_testimonial.name}
                        class="w-10 h-10 rounded-full object-cover grayscale"
                      />
                    )}
                    <div class="flex flex-col">
                      <span class="text-xs font-bold text-fg-0 uppercase tracking-widest">
                        {content.external_testimonial.name}
                      </span>
                      <span class="text-xs text-fg-1 uppercase  mt-1">
                        {content.external_testimonial.role}
                        {content.external_testimonial.organization && (
                          <span class="text-xs font-bold text-fg-1   ">
                            , {content.external_testimonial.organization}
                          </span>
                        )}
                      </span>
                    </div>
                  </div>
                </div>
              )
          }

          {
            content.desc_2 && (
              <div class="">
                <p class="text-sm text-fg-1   italic  p-4 text-justify break-words">
                  {content.desc_2}
                </p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

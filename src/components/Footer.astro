---
import ThemeToggle from "./ThemeToggle.tsx";
import type { LinkColumn } from "../types";

interface Props {
  links: LinkColumn[];
}

const { links } = Astro.props;

const staticLinkColumns: LinkColumn[] = [
  {
    title: "Connect",
    links: [
      { name: "LinkedIn", href: "https://www.linkedin.com/company/nsdc-mec/" },
      { name: "Instagram", href: "https://www.instagram.com/nsdcmec/" },
      { name: "GitHub", href: "https://github.com/nsdcmEC" },
      { name: "Email", href: "mailto:nsdc@mec.ac.in" },
    ],
  },
  {
    title: "Resources",
    links: [
      { name: "NSDC Headquarters", href: "https://nebigdatahub.org/nsdc" },
    ],
  },
];

const allColumns = [...staticLinkColumns, ...links];
allColumns.sort((a, b) => a.links.length - b.links.length);
---

<footer
  class="bg-bg-1 overflow-hidden w-full transition-colors duration-300 border-t border-bg-2"
>
  <div class="py-12 flex flex-row justify-between gap-4 px-4 w-full">
    <div class="flex-shrink-0">
      <img
        src="/logo.png"
        alt="NSDC MEC Logo"
        width="100"
        height="100"
        class="h-24 w-auto"
      />
    </div>
    <div class="flex flex-wrap justify-end gap-x-4 gap-y-12">
      {
        allColumns.map((column) => (
          <div class="flex flex-col space-y-4 items-end w-max">
            <h3 class="font-semibold font-sans tracking-wider uppercase text-sm text-fg-0 text-right">
              {column.title}
            </h3>
            <div class="flex flex-col space-y-3 w-full items-end">
              {column.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="relative w-fit group text-fg-1 hover:text-fg-0 transition-colors duration-300 font-sans"
                  title={link.desc}
                >
                  <span>{link.name}</span>
                  <span class="absolute bottom-0 right-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-right" />
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <div class="relative h-48 w-full">
    <div
      class="absolute bottom-4 left-4 md:left-8 md:bottom-8 flex flex-col space-y-4 items-center md:justify-center"
    >
      <ThemeToggle client:load />
      <div class="text-sm text-fg-1 font-sans">
        &copy; {new Date().getFullYear()} NSDC MEC
      </div>
    </div>
    <div
      aria-hidden="true"
      class="absolute bottom-0 right-0 translate-x-10 lg:translate-x-30 md:translate-x-25 md:translate-y-1/6 scale-y-140 scale-x-80 select-none pointer-events-none"
    >
      <p
        class="text-right text-[28vw] md:text-[12rem] lg:text-[16rem] flex-col-reverse md:flex-row flex leading-none font-extrabold tracking-tighter text-fg-0/10 whitespace-nowrap font-sans"
      >
        <span>NSDC</span><span>MEC</span>
      </p>
    </div>
  </div>
</footer>

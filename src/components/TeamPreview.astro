---
interface Props {
  imageUrl: string;
}

const { imageUrl } = Astro.props;
---

<section class="py-16 lg:py-24 bg-bg-0">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    {
      (
        <div class="mb-8">
          <p class="text-md font-semibold text-fg-0">NSDC Core</p>
          <h2 class="mt-2 text-4xl lg:text-5xl font-serif font-medium text-fg-0">
            OUR TEAM
          </h2>
        </div>
      )
    }
    <div class="w-full overflow-hidden">
      <img
        src={imageUrl}
        width={1024}
        height={1024}
        alt="A snapshot of the team working collaboratively"
        class="w-full h-auto object-cover"
      />
    </div>
    {
      (
        <div class="mt-10 text-center">
          <a
            href={"/teams"}
            class="inline-block py-3 px-8 text-sm font-bold bg-fg-0 text-bg-0 rounded-md hover:bg-fg-1 transition-colors"
          >
            View Our Team
          </a>
        </div>
      )
    }
  </div>
</section>

---
interface Props {
  imageUrl: string;
  isPreview?: boolean;
}

const { imageUrl, isPreview } = Astro.props;
---

<section class="py-16 lg:py-24 bg-[#FAF9F6]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    {
      isPreview && (
        <div class="mb-8">
          <p class="text-md font-semibold text-gray-800">NSDC Core</p>
          <h2 class="mt-2 text-4xl lg:text-5xl font-serif font-medium text-gray-900">
            OUR TEAM
          </h2>
        </div>
      )
    }
    <div class="w-full overflow-hidden">
      <img
        src={imageUrl}
        alt="A snapshot of the team working collaboratively"
        class="w-full h-auto object-cover"
      />
    </div>
    {
      isPreview && (
        <div class="mt-10 text-center">
          <a
            href={"/teams"}
            class="inline-block py-3 px-8 text-sm font-bold bg-gray-900 text-white rounded-md hover:bg-black transition-colors"
          >
            View Our Team
          </a>
        </div>
      )
    }
  </div>
</section>


---
// src/components/Resources.astro
import type { Resource } from "../types";

interface Props {
  resources: Resource[];
  isPreview?: boolean;
}

const { resources, isPreview } = Astro.props;
const displayResources = isPreview ? resources.slice(0, 2) : resources;

// Helper function to format dates
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });
};
---

<section class="py-16 lg:py-24 bg-[#FAF9F6]">
  <div class="px-4">
    <div class="grid grid-cols-1 lg:grid-cols-12 lg:gap-x-12">
      <div class="lg:col-span-3 mb-10 lg:mb-0">
        <h2 class="text-lg font-semibold text-gray-800 lg:sticky lg:top-24">
          Resources
        </h2>
      </div>
      <div class="lg:col-span-9">
        {
          displayResources.length > 0 ? (
            <div class="space-y-12">
              {displayResources.map((resource, index) => (
                <>
                  
                    href={resource.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="block group"
                    aria-label={`Read more about ${resource.title}`}
                  >
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-x-8 items-center">
                      <div class="md:col-span-7 order-2 md:order-1 mt-4 md:mt-0">
                        <p class="text-sm text-gray-500 mb-2">{formatDate(resource.date)}</p>
                        <h3 class="text-3xl font-serif font-medium text-gray-900 transition-colors group-hover:text-gray-600">
                          {resource.title}
                        </h3>
                        <p class="mt-3 text-gray-700 leading-relaxed">{resource.desc}</p>
                      </div>
                      <div class="md:col-span-5 order-1 md:order-2">
                        <img
                          src={resource.img}
                          alt={resource.title}
                          class="w-full h-auto object-cover"
                        />
                      </div>
                    </div>
                  </a>
                  {index < displayResources.length - 1 && (
                    <hr class="border-gray-200" />
                  )}
                </>
              ))}
            </div>
          ) : (
            <p class="text-center text-gray-500">No resources to display.</p>
          )
        }
        {
          isPreview && resources.length > 2 && (
            <div class="mt-12 text-center">
              
                href="/resources"
                class="inline-block py-3 px-8 text-sm font-bold bg-gray-900 text-white rounded-md hover:bg-black transition-colors"
              >
                More Resources
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

---
import type { Resource } from "../types";
import { getTarget, getRel } from "../lib/link-utils";

interface Props {
  title: string;
  resources: Resource[];
}

const { title, resources } = Astro.props;

const formatDate = (dateStr: string | null) => {
  if (!dateStr) return "TBA";
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<section
  class="py-16 lg:py-24 bg-bg-0 transition-colors duration-300 border-t border-bg-2"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-3">
        <div class="lg:sticky lg:top-24">
          <h2
            class="text-4xl font-bold font-sans text-fg-0 tracking-tight mb-4"
          >
            {title}
          </h2>
          <p class="text-fg-1 font-sans text-sm leading-relaxed"></p>
        </div>
      </div>

      <div class="lg:col-span-9">
        {
          resources.length > 0 ? (
            <div class="flex flex-col gap-12">
              {resources.map((resource) => (
                <div
                  class="group block relative"
                  aria-label={`View ${resource.resource_type}: ${resource.title}`}
                >
                  <article class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start relative z-10">
                    <div class="md:col-span-7 order-2 md:order-1 flex flex-col h-full justify-center">
                      <div class="flex items-center gap-3 mb-3">
                        <span class="text-xs font-mono font-bold text-fg-1 uppercase tracking-wider">
                           {formatDate(resource.date)}
                        </span>
                        <div class="h-[1px] flex-grow bg-bg-2" />
                        {resource.resource_type && (
                             <span class="text-[10px] font-bold uppercase tracking-widest bg-primary text-primary-fg px-2 py-0.5 rounded-sm">
                                {resource.resource_type}
                             </span>
                        )}
                      </div>

                      <h3 class="text-2xl md:text-3xl font-sans font-bold text-fg-0 mb-3 group-hover:text-primary transition-colors duration-200">
                        {resource.title}
                      </h3>

                      {resource.tags && resource.tags.length > 0 && (
                        <div class="flex flex-wrap gap-2 mb-4">
                            {resource.tags.map(tag => (
                                <span class="text-[10px] font-bold uppercase tracking-tight bg-bg-2 text-fg-1 px-2 py-0.5 border border-fg-0/5 rounded-sm">
                                    {tag}
                                </span>
                            ))}
                        </div>
                       )}

                      <p class="text-fg-1 font-sans text-base leading-relaxed mb-4">
                        {resource.description}
                      </p>

                      {resource.metadata && (
                        <div class="flex flex-col gap-2 text-sm text-fg-1 mb-6 font-mono border-l-2 border-bg-2 pl-3">
                          {resource.metadata.authors && resource.metadata.authors.length > 0 && (
                            <div class="flex flex-wrap gap-1 items-baseline">
                               <span class="font-bold text-fg-0/60 uppercase text-[9px] tracking-[0.2em] mr-2">
                                 {resource.metadata.authors.length === 1 ? "Author" : "Authors"}
                               </span>
                               {resource.metadata.authors.map((author, index) => (
                                 <span>
                                   {author.link ? (
                                     <a href={author.link} target={getTarget(author.link)} rel={getRel(author.link)} class="font-medium text-fg-0 hover:text-primary transition-colors border-b border-transparent hover:border-primary relative z-20">
                                       {author.name}
                                     </a>
                                   ) : (
                                     <span class="font-medium text-fg-0">
                                       {author.name}
                                     </span>
                                   )}
                                   {index < (resource.metadata.authors?.length || 0) - 1 && <span class="text-fg-1/50 mr-1">,</span>}
                                 </span>
                               ))}
                            </div>
                          )}
                           {resource.metadata.publishers && resource.metadata.publishers.length > 0 && (
                            <div class="flex flex-wrap gap-1 items-baseline">
                               <span class="font-bold text-fg-0/60 uppercase text-[9px] tracking-[0.2em] mr-2">
                                 {resource.metadata.publishers.length === 1 ? "Publisher" : "Publishers"}
                               </span>
                               {resource.metadata.publishers.map((publisher, index) => (
                                 <span>
                                   {publisher.link ? (
                                     <a href={publisher.link} target={getTarget(publisher.link)} rel={getRel(publisher.link)} class="font-medium text-fg-0 hover:text-primary transition-colors border-b border-transparent hover:border-primary relative z-20">
                                       {publisher.name}
                                     </a>
                                   ) : (
                                     <span class="font-medium text-fg-0">
                                       {publisher.name}
                                     </span>
                                   )}
                                   {index < (resource.metadata.publishers?.length || 0) - 1 && <span class="text-fg-1/50 mr-1">,</span>}
                                 </span>
                               ))}
                            </div>
                          )}
                          {resource.metadata.version && (
                            <div class="flex items-baseline gap-2">
                               <span class="font-bold text-fg-0/60 uppercase text-[9px] tracking-[0.2em]">Version</span>
                               <span class="text-xs text-fg-1">{resource.metadata.version}</span>
                            </div>
                          )}
                           {resource.metadata.doi && (
                            <div class="flex items-baseline gap-2">
                               <span class="font-bold text-fg-0/60 uppercase text-[9px] tracking-[0.2em]">DOI</span>
                               <span class="text-xs text-fg-1">{resource.metadata.doi}</span>
                            </div>
                          )}
                        </div>
                      )}
                      
                      {resource.metadata && resource.metadata.additional_html && (
                          <div class="mb-4 text-fg-1 text-sm prose prose-sm prose-invert" set:html={resource.metadata.additional_html} />
                      )}

                      <a
                        href={resource.link || "#"}
                        target={getTarget(resource.link)}
                        rel={getRel(resource.link)}
                        class="mt-2 w-max relative group/btn flex items-center text-primary font-bold text-sm gap-2 cursor-pointer"
                      >
                        <span>{resource.button_text || "View Details"}</span>
                        <span class="absolute bottom-0 left-0 w-full h-[1px] bg-primary transform scale-x-0 group-hover/btn:scale-x-100 transition-transform duration-300 origin-right group-hover:origin-left"></span>
                      </a>
                    </div>

                    <div class="md:col-span-5 order-1 md:order-2">
                      <div class="overflow-hidden bg-bg-2 aspect-[4/3] md:aspect-[3/2] border border-bg-2 rounded-sm relative">
                        {resource.image_url ? (
                            <img
                              width={300}
                              height={300}
                              src={resource.image_url}
                              alt={resource.title}
                              class="w-full h-full object-cover"
                            />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center bg-bg-2 text-fg-1/20">
                                <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        )}
                      </div>
                    </div>
                  </article>

                  <div class="absolute -bottom-6 left-0 right-0 h-[1px] bg-bg-2 group-last:hidden" />
                </div>
              ))}
            </div>
          ) : (
            <div class="py-12 text-center border border-dashed border-bg-2 ">
              <p class="text-fg-1 font-sans">
                No {title.toLowerCase()} available at the moment.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

---
import type { Project } from "../types";

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section
  class="py-16 lg:py-24 bg-bg-0 transition-colors duration-300 border-t border-bg-2"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-3">
        <div class="sticky top-24">
          <h2
            class="text-4xl font-bold font-sans text-fg-0 tracking-tight mb-4"
          >
            Projects
          </h2>
          <p class="text-fg-1 font-sans text-sm leading-relaxed"></p>
        </div>
      </div>

      <div class="lg:col-span-9">
        {
          projects.length > 0 ? (
            <div class="flex flex-col gap-12">
              {projects.map((project) => (
                <a
                  href={project.link || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block relative"
                  aria-label={`View project: ${project.title}`}
                >
                  <article class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
                    <div class="md:col-span-7 order-2 md:order-1 flex flex-col h-full justify-center">
                      <div class="flex items-center gap-3 mb-3">
                        <span class="text-xs font-mono font-bold text-fg-1 uppercase tracking-wider">
                          {project.date}
                        </span>
                        <div class="h-[1px] flex-grow bg-bg-2" />
                      </div>

                      <h3 class="text-2xl md:text-3xl font-sans font-bold text-fg-0 mb-3 group-hover:text-primary transition-colors duration-200">
                        {project.title}
                      </h3>

                      <p class="text-fg-1 font-sans text-base leading-relaxed">
                        {project.desc}
                      </p>

                      <div class="mt-6 flex items-center text-primary font-bold text-sm gap-2 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                        <span>View Project</span>
                        <svg
                          class="w-4 h-4"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                          />
                        </svg>
                      </div>
                    </div>

                    <div class="md:col-span-5 order-1 md:order-2">
                      <div class="overflow-hidden  bg-bg-2 aspect-[4/3] md:aspect-[3/2] border border-bg-2">
                        <img
                          width={300}
                          height={300}
                          src={project.img}
                          alt={project.title}
                          class="w-full h-full object-cover transition-transform duration-500 "
                        />
                      </div>
                    </div>
                  </article>

                  <div class="absolute -bottom-6 left-0 right-0 h-[1px] bg-bg-2 group-last:hidden" />
                </a>
              ))}
            </div>
          ) : (
            <div class="py-12 text-center border border-dashed border-bg-2 ">
              <p class="text-fg-1 font-sans">
                No projects available to display.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

---
import type { Report } from "../types";
import { formatDate } from "../lib/date-utils";

interface Props {
  reports: Report[];
}

const { reports } = Astro.props;
---

<section class="py-16 lg:py-24 bg-bg-0 transition-colors duration-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-3">
        <div class="lg:sticky lg:top-24">
          <h2
            class="text-4xl font-bold font-sans text-fg-0 tracking-tight mb-4"
          >
            Reports
          </h2>
          <p class="text-fg-1 font-sans text-sm leading-relaxed"></p>
        </div>
      </div>

      <div class="lg:col-span-9">
        {
          reports.length > 0 ? (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {reports.map((report) => (
                <article class="group flex flex-col h-full bg-bg-1 p-4 gap-4 border border-bg-2  overflow-hidden  hover:border-fg-0/20 transition-all duration-300">
                  <div class="relative w-full aspect-square  overflow-hidden">
                    <img
                      src={report.img}
                      width={300}
                      height={300}
                      alt={report.title}
                      class="w-full h-full "
                      loading="eager"
                    />
                  </div>
                  <div class="flex flex-col flex-grow ">
                    {report.date && (
                      <div class="mb-3">
                        <span class="text-xs font-mono font-bold text-fg-1 uppercase tracking-wider">
                          {formatDate(report.date)}
                        </span>
                      </div>
                    )}

                    <h3 class="text-xl font-bold font-sans text-fg-0 leading-tight mb-3 group-hover:text-primary transition-colors">
                      {report.title}
                    </h3>

                    <p class="text-sm text-fg-1 font-sans leading-relaxed flex-grow line-clamp-3">
                      {report.desc}
                    </p>

                    <div class="mt-6 pt-4 border-t border-bg-2 flex items-center justify-between">
                      <a
                        href={"/report/" + report.id}
                        class="text-sm relative font-bold text-fg-0 group-hover:text-primary transition-colors inline-flex items-center gap-2"
                      >
                        Read Report
                        <svg
                          class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M17 8l4 4m0 0l-4 4m4-4H3"
                          />
                        </svg>
                        <span class="absolute bottom-0 left-0 h-[1px] w-full bg-fg-0 transform scale-x-0 origin-right transition-transform duration-300 ease-out group-hover:scale-x-100 group-hover:origin-left" />
                      </a>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="py-12 text-center border border-dashed border-bg-2 rounded-lg">
              <p class="text-fg-1 font-sans">
                No reports available at the moment.
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

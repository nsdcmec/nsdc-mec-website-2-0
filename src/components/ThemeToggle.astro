---

---

<theme-toggle>
  <div class="flex items-center">
    <button
      id="theme-btn-light"
      aria-label="Light Mode"
      class="theme-btn p-1.5 text-fg-1 hover:text-fg-0 transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"
        ></path></svg
      >
    </button>
    <button
      id="theme-btn-dark"
      aria-label="Dark Mode"
      class="theme-btn p-1.5 text-fg-1 hover:text-fg-0 transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
        ></path></svg
      >
    </button>
    <button
      id="theme-btn-system"
      aria-label="System Mode"
      class="theme-btn p-1.5 text-fg-1 hover:text-fg-0 transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        ></path></svg
      >
    </button>
  </div>
</theme-toggle>

<script>
  class ThemeToggle extends HTMLElement {
    constructor() {
      super();
      this.init();

      document.addEventListener("astro:after-swap", () => this.init());
    }

    init() {
      const btns = {
        light: this.querySelector("#theme-btn-light"),
        dark: this.querySelector("#theme-btn-dark"),
        system: this.querySelector("#theme-btn-system"),
      };

      Object.entries(btns).forEach(([theme, btn]) => {
        if (!btn) return;

        const newBtn = btn.cloneNode(true);
        btn.parentNode?.replaceChild(newBtn, btn);

        newBtn.addEventListener("click", () => this.setTheme(theme));
      });

      const currentTheme = localStorage.getItem("theme") || "system";
      this.updateActiveButton(currentTheme);
    }

    setTheme(theme) {
      const root = document.documentElement;

      root.classList.remove("light", "dark");
      if (theme !== "system") {
        root.classList.add(theme);
        localStorage.setItem("theme", theme);
      } else {
        localStorage.removeItem("theme");
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          root.classList.add("dark");
        }
      }

      this.updateActiveButton(theme);
    }

    updateActiveButton(theme) {
      const activeClass = "bg-primary text-primary-fg rounded-sm ";
      const inactiveClass = "text-fg-1 hover:text-fg-0 bg-bg-2";

      ["light", "dark", "system"].forEach((t) => {
        const btn = this.querySelector(`#theme-btn-${t}`);
        if (!btn) return;

        if (t === theme) {
          btn.className = `theme-btn p-1.5  transition-colors ${activeClass}`;
        } else {
          btn.className = `theme-btn p-1.5  transition-colors ${inactiveClass}`;
        }
      });
    }
  }

  customElements.define("theme-toggle", ThemeToggle);
</script>

---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { LinkColumn } from "../types";

interface Props {
  title: string;
  links: LinkColumn[];
}

const { title, links } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="NSDC MEC Website" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://ik.imagekit.io" />
    <title>{title}</title>

    <ClientRouter />
    <script is:inline>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return "system";
      };

      const applyTheme = (theme) => {
        const root = document.documentElement;
        root.classList.remove("light", "dark");
        if (theme === "dark") root.classList.add("dark");
        if (theme === "light") root.classList.add("light");
      };

      applyTheme(getTheme());

      document.addEventListener("astro:after-swap", () =>
        applyTheme(getTheme()),
      );
    </script>
  </head>
  <body class="antialiased min-h-screen flex flex-col overflow-x-hidden">
    <div transition:persist="header" class="sticky top-0 z-50 w-full">
      <Header />
    </div>

    <main class="flex-grow w-full" transition:name="main">
      <slot />
    </main>

    <Footer links={links} />
  </body>
</html>

---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type {
  Link,
  GlobalInjections,
  TopHtmlConfig,
  ThemeColors,
} from "../types";

interface Props {
  title: string;
  links: Link[];
  injections?: GlobalInjections;
  colors: ThemeColors | undefined;
  description?: string | null;
  image?: string | null;
  defaultTheme: string;
}

const { title, links, injections, colors, description, image, defaultTheme } =
  Astro.props;

const metaDescription =
  description ||
  "Official website of National Students Data Corps (NSDC) MEC Chapter.";
const metaImage =
  image || "https://ik.imagekit.io/LOL123/opengraph.png?tr=f-webp";

const topHtmlRaw = injections?.top_html;
let topHtmlConfig: TopHtmlConfig | null = null;

if (topHtmlRaw) {
  if (typeof topHtmlRaw === "string") {
    topHtmlConfig = { html: topHtmlRaw, is_active: true, should_close: true };
  } else {
    topHtmlConfig = topHtmlRaw;
  }
}

const showTopHtml = topHtmlConfig?.is_active && topHtmlConfig?.html;

const footerSlotRaw = injections?.footer_slot;
const showFooterSlot =
  typeof footerSlotRaw === "string"
    ? !!footerSlotRaw
    : footerSlotRaw?.is_active && footerSlotRaw?.html;
const footerSlotHtml =
  typeof footerSlotRaw === "string" ? footerSlotRaw : footerSlotRaw?.html;

const generateThemeStyles = (colors?: ThemeColors) => {
  const fallbacks = {
    light: {
      bg0: "#faf9f6",
      bg1: "#ffffff",
      bg2: "#e5e7eb",
      fg0: "#101828",
      fg1: "#475467",
      primary: "#101828",
      primaryFg: "#ffffff",
    },
    dark: {
      bg0: "#0b111d",
      bg1: "#162032",
      bg2: "#1f2937",
      fg0: "#f9fafb",
      fg1: "#9ca3af",
      primary: "#f9fafb",
      primaryFg: "#101828",
    },
  };

  const light = colors?.light || fallbacks.light;
  const dark = colors?.dark || fallbacks.dark;

  let css = "";

  css += `html:root {\n`;
  if (light.bg0) css += `--bg-0: ${light.bg0};\n`;
  if (light.bg1) css += `--bg-1: ${light.bg1};\n`;
  if (light.bg2) css += `--bg-2: ${light.bg2};\n`;
  if (light.fg0) css += `--fg-0: ${light.fg0};\n`;
  if (light.fg1) css += `--fg-1: ${light.fg1};\n`;
  if (light.primary) css += `--primary: ${light.primary};\n`;
  if (light.primaryFg) css += `--primary-fg: ${light.primaryFg};\n`;
  css += `}\n`;

  let darkRules = "";
  if (dark.bg0) darkRules += `--bg-0: ${dark.bg0};\n`;
  if (dark.bg1) darkRules += `--bg-1: ${dark.bg1};\n`;
  if (dark.bg2) darkRules += `--bg-2: ${dark.bg2};\n`;
  if (dark.fg0) darkRules += `--fg-0: ${dark.fg0};\n`;
  if (dark.fg1) darkRules += `--fg-1: ${dark.fg1};\n`;
  if (dark.primary) darkRules += `--primary: ${dark.primary};\n`;
  if (dark.primaryFg) darkRules += `--primary-fg: ${dark.primaryFg};\n`;

  css += `html:root.dark {\n${darkRules}}\n`;
  css += `@media (prefers-color-scheme: dark) {\n  html:root:not(.light) {\n${darkRules}  }\n}\n`;

  return css;
};
const themeCss = generateThemeStyles(colors);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="NSDC MEC Website" />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content="dijith481, nitin tony paul, nsdcmec" />

    <!-- Favicons & Manifest -->
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={metaImage} />
    <meta property="og:site_name" content="NSDC MEC" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={metaImage} />

    <link rel="preconnect" href="https://ik.imagekit.io" />
    <title>{title}</title>

    <ClientRouter />
    <slot name="head" />
    {themeCss && <style is:inline set:html={themeCss} />}
    <script is:inline define:vars={{ defaultTheme }}>
      const getTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return defaultTheme || "light";
      };

      const applyTheme = (theme) => {
        const root = document.documentElement;
        root.classList.remove("light", "dark");
        if (theme === "dark") root.classList.add("dark");
        if (theme === "light") root.classList.add("light");
        if (theme === "system") {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            root.classList.add("dark");
          }
        }
      };

      applyTheme(getTheme());

      // Apply theme onto the INCOMING document before the swap happens,
      // so the browser never paints a frame without the correct theme class.
      document.addEventListener("astro:before-swap", (e) => {
        const theme = getTheme();
        e.newDocument.documentElement.classList.remove("light", "dark");
        if (theme === "dark") e.newDocument.documentElement.classList.add("dark");
        else if (theme === "light") e.newDocument.documentElement.classList.add("light");
        else if (theme === "system") {
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            e.newDocument.documentElement.classList.add("dark");
          }
        }
      });

      // Belt-and-suspenders: re-apply after swap as well (handles edge cases)
      document.addEventListener("astro:after-swap", () =>
        applyTheme(getTheme()),
      );
    </script>
  </head>
  <body
    class="antialiased min-h-screen flex flex-col overflow-x-hidden bg-bg-0"
  >
    {
      showTopHtml && topHtmlConfig && (
        <div id="top-injection-banner" class="relative w-full z-[60]">
          <div set:html={topHtmlConfig.html} />
          {topHtmlConfig.should_close && (
            <button
              aria-label="Close Announcement"
              onclick="document.getElementById('top-injection-banner').remove()"
              class="absolute top-2 right-2 p-1 bg-black/10 hover:bg-black/20 text-current rounded-full transition-colors cursor-pointer z-50"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"
                />
              </svg>
            </button>
          )}
        </div>
      )
    }

    <div transition:persist="header" class="sticky top-0 z-50 w-full">
      <Header links={links} />
    </div>

    <main class="flex-grow w-full">
      <slot />
    </main>

    {showFooterSlot && <div set:html={footerSlotHtml} />}
    <Footer links={links} />
  </body>
</html>
